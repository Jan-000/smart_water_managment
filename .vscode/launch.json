{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Fastify TS",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect=9229",
        "--import",
        "tsx"
      ],
      "program": "${workspaceFolder}/backend/src/server.ts",
      "env": {
        "PORT": "4000"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**"
      ],
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Frontend: Chrome + Vite",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "frontend: dev",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Frontend Chrome",
      "configurations": [
        "Backend: Fastify TS",
        "Frontend: Chrome + Vite"
      ],
      "stopAll": true
    }
  ]
}
